<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cj.imageagent.mapper.ChatHistoryMapper">

    <resultMap id="BaseResultMap" type="com.cj.imageagent.entity.ChatHistory">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="conversationId" column="conversation_id" jdbcType="VARCHAR"/>
            <result property="content" column="content" jdbcType="VARCHAR"/>
            <result property="mediaData" column="media_data" jdbcType="VARCHAR"/>
            <result property="type" column="type" jdbcType="VARCHAR"/>
            <result property="timestamp" column="timestamp" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,conversation_id,content,
        media_data,type,timestamp
    </sql>
    <select id="getHistorySessionList" resultType="com.cj.imageagent.entity.ChatHistory">
        SELECT
        <include refid="Base_Column_List"/>
        FROM
        chat_history
        WHERE
        conversation_id = #{conversationId}
        ORDER BY
        timestamp ASC
    </select>
</mapper>
